{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Spatial Layer Monitor",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/manage.py",
            "python": "${workspaceFolder}/venv/bin/python",
            "args": [
                "runserver",
                "0.0.0.0:9196"
            ],
            "django": true,
            "autoStartBrowser": false,
        },
        {
            "name": "process_spatial_layers_changes",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/manage.py",
            "python": "${workspaceFolder}/venv/bin/python",
            "args": [
                "process_spatial_layers_changes_command"
            ],
            "django": true,
            "autoReload": {
                "enable": true
            }
        },
        {
            "name": "process_purge_retries",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/manage.py",
            "python": "${workspaceFolder}/venv/bin/python",
            "args": [
                "process_purge_retries_command"
            ],
            "django": true,
            "autoReload": {
                "enable": true
            }
        },
        {
            "name": "delete_old_history (dry-run)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/manage.py",
            "python": "${workspaceFolder}/venv/bin/python",
            "args": [
                "delete_old_history_command",
                "--days",
                "90",
                "--dry-run"
            ],
            "django": true,
            "autoReload": {
                "enable": true
            }
        },
        {
            "name": "delete_old_history",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/manage.py",
            "python": "${workspaceFolder}/venv/bin/python",
            "args": [
                "delete_old_history_command"
            ],
            "django": true,
            "autoReload": {
                "enable": true
            }
        }
    ]
}